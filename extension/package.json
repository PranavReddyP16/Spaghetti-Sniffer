{
  "name": "spaghetti-sniffer",
  "displayName": "Spaghetti Sniffer",
  "description": "Detects Python code smells and roasts you about them using GPT-4o.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [    "onDidOpenTextDocument",
  "onDidSaveTextDocument",
  "onLanguage:python"
],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hackumass.helloWorld",
        "title": "Spaghetti Sniffer: Analyze File"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0"
  },
  "dependencies": {
    "axios": "^1.7.7"
  }
}
